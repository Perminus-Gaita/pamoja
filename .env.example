# ── Database (required) ─────────────────────────────────────────────────────
# Neon serverless Postgres connection string. Tables are created automatically
# on first use.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Photo storage — any S3-compatible object store (recommended) ────────────
# Works with Cloudflare R2, MinIO, DigitalOcean Spaces, or AWS S3.
# Photos are processed once on upload (two WebP derivatives, EXIF stripped)
# and served DIRECTLY from S3_PUBLIC_URL — they never pass through the app
# server or Vercel's image optimizer, so photo bandwidth costs nothing here.
#
# S3 endpoint URL. R2: https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=
# Region — leave "auto" for R2; MinIO/Spaces/AWS use their region name.
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
# Public base URL the bucket is served from (no trailing slash) — e.g. an R2
# custom domain (https://photos.example.com) or r2.dev URL. If unset, photos
# are proxied through /api/images/<key> instead of served directly.
S3_PUBLIC_URL=

# Legacy Cloudflare R2 config (older deployments) — used only when the S3_*
# vars above are absent; the bucket stays private and photos are proxied
# through /api/images/<key>. Prefer the S3_* vars for new setups.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# With neither S3_* nor R2_* set, photos are stored on the local filesystem
# (self-host fallback; not for Vercel — its filesystem is ephemeral).
# Directory for local photo storage, default ./uploads
# UPLOADS_DIR=

# ── Auth (required) ──────────────────────────────────────────────────────────
# Random secret for session signing — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL of the deployment, e.g. https://memorial.example.com
# (leave unset in local dev — it is inferred from the request)
BETTER_AUTH_URL=

# There is no admin bootstrap variable: the account that creates the memorial
# is its admin. (Optional operator override for managed hosting below.)
# ADMIN_EMAILS=ops@example.com

# Platform admin — the site developer/operator (sees /platform-admin).
# The account with this email gets user."isPlatformAdmin" = TRUE on init.
PLATFORM_ADMIN_EMAIL=

# ── Social sign-in providers (all optional) ──────────────────────────────────
# Set a pair of credentials to activate that provider on the sign-in page.
# Register the OAuth app on each platform with this callback URL:
#   <your-domain>/api/auth/callback/<provider>
# Email + password sign-in always works, even with none of these set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Password reset email — Resend (optional) ─────────────────────────────────
# Powers the "Forgot password?" flow on /sign-in. Without these, email+password
# sign-in still works, but users who forget their password have no self-service
# recovery. Get an API key at resend.com and verify a sending domain there.
RESEND_API_KEY=
# Verified sender, e.g. "Pamoja <noreply@yourdomain.com>"
RESEND_FROM_EMAIL=

# ── Operator notifications — Telegram (optional) ────────────────────────────
# Ping the operator when a visitor leaves contact details (contact form,
# memorial requests). Create a bot with @BotFather, message it once, then set:
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram chat ids to notify (get yours from @userinfobot)
ADMINS_TELEGRAM_IDS=

# ── AI assistant (optional) ──────────────────────────────────────────────────
# Enables the public "Ask a question" widget and the admin AI assistant.
ANTHROPIC_API_KEY=

# ── Multi-memorial setup (optional) ──────────────────────────────────────────
# Root domain serving the memorial directory; memorials live on subdomains.
NEXT_PUBLIC_ROOT_DOMAIN=

# ── Deployment mode (optional) ───────────────────────────────────────────────
# 'selfhost' (default): every feature enabled, free.
# 'managed': paid enhancements (relation tree, galleries, contributions,
# program page, AI entry/triage) are gated by the memorial's plan.
# Condolences and the primary photo are NEVER gated in any mode.
NEXT_PUBLIC_DEPLOYMENT_MODE=selfhost
